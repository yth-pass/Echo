# ==============================================================================
# Echo Production Environment Variables
# Copy to .env.production and fill in the actual values.
# ==============================================================================

# ---- Database (PostgreSQL + pgvector) ----
DB_NAME=echo_db
DB_USER=echo_user
DB_PASSWORD=CHANGE_ME__generate_a_strong_password

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME__generate_a_strong_password

# ---- JWT ----
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME__generate_a_strong_random_string

# ---- AI / LLM APIs ----
DEEPSEEK_API_KEY=sk-your-deepseek-key
DASHSCOPE_API_KEY=sk-your-dashscope-key

# ---- Alibaba Cloud SMS (for phone OTP) ----
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_CODE_VALID_MINUTES=5

# ---- Tencent Cloud COS (optional, for file uploads) ----
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai

# ---- Frontend URL (public-facing URL) ----
# During ICP filing: http://124.223.73.232
# After ICP filing + SSL: https://your-domain.com
FRONTEND_URL=http://124.223.73.232
