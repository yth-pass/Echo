*.bak

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
# Windows reserved device names — 绝对不能进入仓库
nul
prn
con
aux

# Android / Gradle
apps/android/.gradle/
apps/android/**/build/
apps/android/local.properties
*.apk
*.aab

# Prisma / misc
*.tsbuildinfo
tmp/echo-update.tar.gz

# Large binary / generated directories — never commit these
