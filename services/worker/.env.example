# --- 本地开发（无 Docker）：Neon (Postgres) + Upstash (Redis) ---
# 必须与 services/api/.env 中的 DATABASE_URL 和 REDIS_URL 完全一致
DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<database>?sslmode=require&schema=public
REDIS_URL=rediss://default:<upstash-token>@<name>-<id>.upstash.io:6379

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
