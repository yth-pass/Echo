PORT=4000

# --- 本地开发（无 Docker）：Neon (Postgres) + Upstash (Redis) ---
# 注册 Neon 和 Upstash 免费账号后，填入连接串（必须包含 sslmode=require）
DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<database>?sslmode=require&schema=public
REDIS_URL=rediss://default:<upstash-token>@<name>-<id>.upstash.io:6379

JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# MVP: OTP printed to API logs; optional fixed code for dev
# ⚠️ 生产环境必须留空，否则可被固定验证码绕过 OTP 校验
# 本地开发填值（如 123456）则走 Redis 明文比对，不调用阿里云短信（省钱）
OTP_DEV_CODE=

# --- 阿里云号码认证服务（Dypnsapi）短信验证码 ---
# OTP_DEV_CODE 留空时启用：验证码由阿里云生成下发，校验回调阿里云 CheckSmsVerifyCode
# 凭证在阿里云 RAM 访问控制 → AccessKey 管理 获取
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 短信签名（控制台审核通过的签名内容，如「速通互联验证码」）
SMS_SIGN_NAME=
# 短信模板 ID（控制台审核通过，如「100001」）
SMS_TEMPLATE_CODE=
# 验证码有效期（分钟），与模板正文里的 min 占位符一致
SMS_CODE_VALID_MINUTES=5

# --- 腾讯云 COS（对象存储，头像上传）---
# 留空时头像上传自动回退为 Base64 存入数据库（本地开发可接受）
# 生产环境建议配置 COS 以减少数据库膨胀
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai
