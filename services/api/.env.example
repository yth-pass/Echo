PORT=4000

# --- Local Docker Compose (infra/docker-compose.yml) ---
DATABASE_URL=postgresql://echo:echo_dev@localhost:5432/echo?schema=public
REDIS_URL=redis://localhost:6379

# --- Cloud free tier (Neon + Upstash, no Docker) — see infra/README-native-windows.md ---
# DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<database>?sslmode=require&schema=public
# REDIS_URL=rediss://default:<upstash-token>@<name>-<id>.upstash.io:6379

JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# MVP: OTP printed to API logs; optional fixed code for dev
OTP_DEV_CODE=123456
