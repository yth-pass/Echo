# DeepSeek (OpenAI-compatible API). See https://api-docs.deepseek.com/
# For local Vite dev only: keys prefixed with VITE_ are exposed to the browser bundle.
# Do NOT ship a public build with a real key; use a backend proxy in production.
# VITE_DEEPSEEK_API_KEY="sk-..."
# VITE_DEEPSEEK_BASE_URL="https://api.deepseek.com"
# VITE_DEEPSEEK_MODEL="deepseek-chat"

# Server-side / CI (e.g. Node scripts) — not read by Vite unless you load dotenv yourself.
# DEEPSEEK_API_KEY="sk-..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Echo Platform REST base URL including `/v1` (Software Architecture §10).
# Leave empty to use mock data only. Example: http://localhost:4000/v1
# VITE_API_BASE_URL="http://localhost:4000/v1"
# WebSocket live events use the same host: ws://localhost:4000/v1/ws?token=<access_token>
