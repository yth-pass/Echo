    <!-- M2 scenarios -->
    <string name="scenario_weekend_q">Friend asks "plans this weekend?", you\'d most likely reply:</string>
    <string name="scenario_weekend_a">Depends — might just sleep in; ping me if there\'s a plan.</string>
    <string name="scenario_weekend_b">Let\'s go! Exhibition / hike / new spot — list\'s ready.</string>
    <string name="scenario_weekend_c">Haha whatever, you pick — I\'ll bring snacks.</string>
    <string name="scenario_disagree_q">You disagree with them, you usually:</string>
    <string name="scenario_disagree_a">Hear them out, then gently say "I get it, but for me…"</string>
    <string name="scenario_disagree_b">State my reasons directly — firm but not personal.</string>
    <string name="scenario_disagree_c">Laugh it off, dodge — won\'t argue early on.</string>
    <string name="scenario_match_q">Match texts "you there?", you\'d most likely:</string>
    <string name="scenario_match_a">Yeah, just wrapped up — how\'s your day?</string>
    <string name="scenario_match_b">Hi~ saw you also like XX, me too!</string>
    <string name="scenario_match_c">Yeah here — chat later? Bit busy now.</string>
    <string name="scenario_excitement_q">Friend shares exciting news, you usually:</string>
    <string name="scenario_excitement_a">Wow!! Tell me everything, I\'m fully here.</string>
    <string name="scenario_excitement_b">That\'s great — what happened exactly?</string>
    <string name="scenario_excitement_c">Nice, drinks on you!</string>
    <string name="scenario_comfort_q">Friend is down, your first instinct is:</string>
    <string name="scenario_comfort_a">Don\'t be sad, I\'m here — cry if you need to.</string>
    <string name="scenario_comfort_b">They don\'t deserve you — come, food\'s on me.</string>
    <string name="scenario_comfort_c">What happened? Take your time, I\'m here.</string>
    <string name="scenario_vent_q">When something bugs you, you vent like:</string>
    <string name="scenario_vent_a">Voice-note barrage, rapid fire.</string>
    <string name="scenario_vent_b">Screenshot + "save me", wait for them to bite.</string>
    <string name="scenario_vent_c">Two sarcastic lines then drop it.</string>

