    <!-- M2 场景 -->
    <string name="scenario_weekend_q">朋友问「这周末干嘛」，你最像会回复：</string>
    <string name="scenario_weekend_a">看情况，可能宅家补觉，有局再叫我。</string>
    <string name="scenario_weekend_b">冲！展览/徒步/新餐厅，清单已写好。</string>
    <string name="scenario_weekend_c">哈哈随缘，你定吧，我负责带零食。</string>
    <string name="scenario_disagree_q">聊天里对方观点和你相反，你更常：</string>
    <string name="scenario_disagree_a">先听完，委婉说「我理解，不过我这边是…」</string>
    <string name="scenario_disagree_b">直接讲理由，语气硬但不对人。</string>
    <string name="scenario_disagree_c">打哈哈岔开，少在初聊里杠。</string>
    <string name="scenario_match_q">匹配对象发来「在吗」，你更可能：</string>
    <string name="scenario_match_a">在的，刚忙完，你今天怎么样？</string>
    <string name="scenario_match_b">在～看到你喜欢 XX，我也！</string>
    <string name="scenario_match_c">嗯在，晚点细聊？这会儿手头事。</string>
    <string name="scenario_excitement_q">朋友兴奋地找你分享好消息，你通常怎么接：</string>
    <string name="scenario_excitement_a">哇！！快说快说，我现在就坐在你这边。</string>
    <string name="scenario_excitement_b">挺好的呀，具体咋回事？</string>
    <string name="scenario_excitement_c">牛啊，请客请客。</string>
    <string name="scenario_comfort_q">朋友失恋/受挫了，你第一反应会说：</string>
    <string name="scenario_comfort_a">别难过了，我陪你，想哭就哭。</string>
    <string name="scenario_comfort_b">那人配不上你，走，吃顿好的去。</string>
    <string name="scenario_comfort_c">发生啥了？慢慢说，我在。</string>
    <string name="scenario_vent_q">遇到无语的事，你跟朋友吐槽通常是这样：</string>
    <string name="scenario_vent_a">一通语音轰炸，连珠炮式输出。</string>
    <string name="scenario_vent_b">截个图配一句"救命"，等对方接。</string>
    <string name="scenario_vent_c">阴阳怪气两句就过，懒得细说。</string>

