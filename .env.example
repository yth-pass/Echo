# =============================================================================
# Echo 项目环境变量模板 (.env.example)
# -----------------------------------------------------------------------------
# 用途：本文件为示例模板，提交到仓库供开发者参考。所有敏感值均为占位符。
#       真实凭证请填写到本地 .env（已被 .gitignore 忽略，不会被提交）。
# 规则：禁止在本文件中填入任何真实密钥、密码、连接串。
# =============================================================================

# -----------------------------------------------------------------------------
# 【API 服务】services/api（NestJS 后端）
# -----------------------------------------------------------------------------
# API 服务监听端口
PORT=4000

# PostgreSQL 数据库连接串（Neon / 自建均可）
# 必须包含 sslmode=require；schema 指定 Prisma 使用的 schema
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&schema=public

# Redis 连接串（Upstash / 自建均可，使用 rediss 协议走 TLS）
REDIS_URL=rediss://default:UPSTASH_TOKEN@HOST.upstash.io:6379

# JWT 签名密钥（生产环境必须使用高强度随机串，至少 32 字节）
# 生成方式：openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-secret

# JWT 访问令牌有效期
JWT_ACCESS_TTL=15m
# JWT 刷新令牌有效期
JWT_REFRESH_TTL=7d

# DeepSeek 大模型 API 密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DeepSeek API 基础地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# 【开发后门】OTP_DEV_CODE
# -----------------------------------------------------------------------------
# ⚠️ 危险：这是开发环境固定 OTP 验证码后门，生产环境必须留空或删除该变量！
# 仅用于本地联调时跳过真实短信/邮件验证码。
# 生产部署时请删除此变量或留空，确保走真实 OTP 流程。
OTP_DEV_CODE=

# -----------------------------------------------------------------------------
# 【共享配置】API 与 Worker 共用
# -----------------------------------------------------------------------------
# 记忆共享目录（API 与 Worker 必须使用相同路径）
# 默认解析到仓库根目录下的 tmp/memory；生产环境建议使用绝对路径
# ECHO_MEMORY_BASE_DIR=../../tmp/memory

# -----------------------------------------------------------------------------
# 【Worker 服务】services/worker（BullMQ 队列消费）
# -----------------------------------------------------------------------------
# Worker 需要与 API 完全一致的 DATABASE_URL 与 REDIS_URL（见上方）
# 以及一致的 DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL

# -----------------------------------------------------------------------------
# 【客户端】Echo/（React + Vite）
# -----------------------------------------------------------------------------
# 客户端应用部署地址（AI Studio 运行时自动注入，本地开发可留默认）
APP_URL=MY_APP_URL

# Echo 平台 REST API 基础地址（含 /v1）；留空则客户端仅使用 mock 数据
# VITE_API_BASE_URL=http://localhost:4000/v1
# WebSocket 实时事件使用相同 host：ws://localhost:4000/v1/ws?token=<access_token>

# -----------------------------------------------------------------------------
# 【安全提醒】
# -----------------------------------------------------------------------------
# 1. 任何真实密钥只能写在本地 .env（已 gitignore），禁止出现在本文件
# 2. 切勿将 .env、.env.local、.env.bak 提交到仓库
# 3. 若密钥曾泄露（误提交/截图/日志），必须立即在各平台轮换，删除文件不等于安全
# 4. 生产环境 OTP_DEV_CODE 必须为空，否则可被任意用户用 123456 绕过验证
